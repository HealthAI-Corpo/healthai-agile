DATABASE_HOST=addresse docker
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=healthai

JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=900
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_EXPIRES_IN=604800

PORT=3000
NODE_ENV=development
# ============================================================
# HealthAI - Configuration Environnement
# Copier ce fichier en .env et ajuster les valeurs
# ============================================================

# PostgreSQL
POSTGRES_DB=healthai
POSTGRES_USER=healthai
POSTGRES_PASSWORD=healthai_secure_pwd
POSTGRES_PORT=5432

# MongoDB
MONGO_PORT=27017
MONGODB_URL=mongodb://mongo:27017

# API Services
HEALTHAI_API_PORT=8000
HEALTHAI_VISION_PORT=8001
HEALTHAI_WORKOUT_PORT=8002

# Frontend
FRONT_PORT=3000

# Hugging Face Models
HF_MODEL_NAME=yolov8n.pt
HF_CACHE_DIR=/app/.hf_cache
